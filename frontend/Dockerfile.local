# Development Dockerfile - Runs Next.js dev server with hot reload
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci

# Copied here; source dirs are mounted as volumes for hot reload
COPY . .

EXPOSE 3000

ENV HOSTNAME=0.0.0.0

CMD ["npm", "run", "dev", "--", "-H", "0.0.0.0", "-p", "3000"]
